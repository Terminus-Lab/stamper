# ── LLM provider ──────────────────────────────────────────────────────────────
# Which provider to use: openai_platform | ollama | openai (azure)
LLM_FAMILY=openai_platform

# Model ID (e.g. gpt-4o, gpt-4o-mini, llama3, etc.)
MODEL_ID=gpt-4o-mini

# ── Provider credentials ───────────────────────────────────────────────────────
# OpenAI Platform
OPEN_AI_KEY=sk-...

# Azure OpenAI
# AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com/

# Ollama (default: http://localhost:11434/v1)
# OLLAMA_BASE_URL=http://localhost:11434/v1

# ── Model settings ─────────────────────────────────────────────────────────────
# Max tokens for the summarize LLM call (default: 1000)
MODEL_MAX_TOKENS=1000

# Sampling temperature — 0.0 = deterministic (default: 0.0)
MODEL_TEMPERATURE=0.0

# ── Features ──────────────────────────────────────────────────────────────────
# Enable [s] summarize — triggers an LLM call for the current conversation.
# Requires LLM_FAMILY, MODEL_ID, and the relevant credential to be set.
# Default: false
STAMPER_SUMMARIZE=false

# Set to false to disable bubbletea TUI and use plain terminal mode (default: true)
# STAMPER_TUI=true
